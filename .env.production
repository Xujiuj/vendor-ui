# 页面标题
VITE_APP_TITLE = 厂商运营管理平台
VITE_APP_LOGO_TITLE = 厂商端

# 生产环境配置
VITE_APP_ENV = 'production'

# 应用访问路径，线上部署在 /vendor/
VITE_APP_CONTEXT_PATH = '/vendor/'

# 监控地址
VITE_APP_MONITOR_ADMIN = '/admin/applications'

# SnailJob 控制台地址
VITE_APP_SNAILJOB_ADMIN = '/snail-job'

# 生产环境接口，线上 nginx 在 /vendor/prod-api 代理后端
VITE_APP_BASE_API = '/vendor/prod-api'

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip

VITE_APP_PORT = 17000
VITE_APP_PROXY_TARGET = 'http://localhost:18000'

# 接口加密功能开关，如需关闭后端也必须对应关闭
VITE_APP_ENCRYPT = true
# 接口加密传输 RSA 公钥，与后端解密私钥对应；如需更换需前后端同时更换
VITE_APP_RSA_PUBLIC_KEY = 'MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKoR8mX0rGKLqzcWmOzbfj64K8ZIgOdHnzkXSOVOZbFu/TJhZ7rFAN+eaGkl3C4buccQd/EjEsj9ir7ijT7h96MCAwEAAQ=='
# 接口响应解密 RSA 私钥，与后端加密公钥对应；如需更换需前后端同时更换
VITE_APP_RSA_PRIVATE_KEY = ''

# 客户端 id
VITE_APP_CLIENT_ID = 'e5cd7e4891bf95d1d19206ce24a7b32e'

# websocket 开关，默认使用 sse 推送
VITE_APP_WEBSOCKET = false

# sse 开关
VITE_APP_SSE = true
